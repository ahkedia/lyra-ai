# ============================================
# LYRA AGENT - Environment Variables
# ============================================
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================

# LLM Configuration
# Get from: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Fallback LLM (Optional - only for complex synthesis tasks)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Configuration
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric ID (not username)
# Get from @userinfobot on Telegram
TELEGRAM_USER_ID=123456789

# Partner's Telegram numeric ID (if applicable)
TELEGRAM_PARTNER_ID=987654321

# WhatsApp Configuration
# Your WhatsApp phone number with country code (e.g., +91XXXXXXXXXX)
WHATSAPP_USER_PHONE=+910000000000

# Evolution API endpoint (running in Docker on same network)
EVOLUTION_API_URL=http://evolution-api:9000

# Notion Configuration
# Get from: https://notion.so/my-integrations
NOTION_API_KEY=ntn_your_notion_integration_key_here

# SuperMemory / Memory Plugin
# Get from: https://supermemory.ai/
SUPERMEMORY_API_KEY=your_supermemory_api_key_here

# Web Search
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# OpenClaw Gateway Security
# Generate with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=your_secure_gateway_token_here

# Optional: Other integrations
# EMAIL_SERVICE_PASSWORD=your_email_password
# SLACK_TOKEN=your_slack_bot_token
# GITHUB_TOKEN=your_github_personal_access_token
