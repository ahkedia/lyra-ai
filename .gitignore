# Dependencies
node_modules/
dist/

# Never commit real credentials or personal config
*.env
.env.*
secrets.json
api_key
config.toml

# Live personal layer — lives in the PRIVATE repo (lyra-private), never here.
# See docs/12-public-private-split.md. Templates (config/*-template.md,
# config/cron-jobs.example.json) stay tracked. Root MEMORY.md is a tracked
# pointer stub, not the live memory.
/SOUL.md
/config/SOUL.md
/config/MEMORY.md
/config/HEARTBEAT.md
/config/cron-jobs.json
/notion/notion.md

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor (track mcp.json + rules/*.mdc; ignore other .cursor churn)
.cursor/*
!.cursor/mcp.json
!.cursor/rules/
!.cursor/rules/*.mdc
.vscode/
*.swp
evals/results/*.jsonl
evals/results/*-summary.json
evals/results/*-routing.json
logs/
.gstack/

# --- lyra-refactor-2026-06-20: ignore regenerated/cache/backup noise ---
evals/output/*.json
evals/results-diagnostic/
**/__pycache__/
*.pyc
*.bak
*.bak-*
*.bak.*
