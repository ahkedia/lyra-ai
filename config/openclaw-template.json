{
  "agents": {
    "defaults": {
      "model": "anthropic/claude-haiku-3-5",
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {}
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      },
      "memorySearch": {
        "enabled": true
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": { "enabled": true },
        "boot-md": { "enabled": true },
        "command-logger": { "enabled": true }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["YOUR_TELEGRAM_NUMERIC_ID", "PARTNER_TELEGRAM_NUMERIC_ID"],
      "allowFrom": ["YOUR_TELEGRAM_NUMERIC_ID", "PARTNER_TELEGRAM_NUMERIC_ID"],
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "GENERATE_WITH: openssl rand -hex 24"
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add"
      ]
    }
  },
  "plugins": {
    "allow": ["openclaw-supermemory", "telegram"],
    "slots": {
      "memory": "openclaw-supermemory"
    },
    "entries": {
      "telegram": { "enabled": true },
      "openclaw-supermemory": {
        "enabled": true,
        "config": {
          "apiKey": "${SUPERMEMORY_API_KEY}",
          "containerTag": "lyra_[YOUR_NAME_LOWERCASE]",
          "autoRecall": true,
          "autoCapture": true,
          "maxRecallResults": 5,
          "profileFrequency": 50,
          "captureMode": "all",
          "debug": false,
          "enableCustomContainerTags": true,
          "customContainers": [
            { "tag": "work", "description": "Work memories: professional role, competitors, content strategy, job-related decisions" },
            { "tag": "household", "description": "Shared household memories: trips, meals, health, shopping, joint decisions with partner" },
            { "tag": "second-brain", "description": "Ideas, insights, decisions, patterns captured from voice and conversation" }
          ],
          "customContainerInstructions": "When the message is from the primary user about work topics — use 'work'. For household/shared topics — use 'household'. For insights/ideas/decisions — use 'second-brain'. When the message is from the partner — use 'household' only. Never mix containers."
        }
      }
    }
  }
}
