{
  "agents": {
    "defaults": {
      "model": "minimax/MiniMax-M2.7",
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {}
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      },
      "memorySearch": {
        "enabled": true
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": { "enabled": true },
        "boot-md": { "enabled": true },
        "command-logger": { "enabled": true }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["${TELEGRAM_USER_ID}", "${TELEGRAM_PARTNER_ID}"],
      "allowFrom": ["${TELEGRAM_USER_ID}", "${TELEGRAM_PARTNER_ID}"],
      "streaming": "off"
    },
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${WHATSAPP_USER_PHONE}"]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "remote",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add"
      ]
    }
  },
  "plugins": {
    "allow": ["telegram", "whatsapp"],
    "entries": {
      "telegram": { "enabled": true },
      "whatsapp": { "enabled": true }
    }
  }
}
