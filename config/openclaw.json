{
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax-direct/MiniMax-M2.7",
        "fallbacks": [
          "anthropic/claude-haiku-4-5",
          "anthropic/claude-sonnet-4-6"
        ]
      },
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {}
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      },
      "memorySearch": {
        "enabled": false
      },
      "models": {
        "anthropic/claude-3-7-sonnet-20250219": {},
        "anthropic/claude-3-5-haiku-latest": {},
        "anthropic/claude-haiku-4-5": {},
        "anthropic/claude-sonnet-4-5": {},
        "anthropic/claude-sonnet-4-6": {},
        "minimax-direct/MiniMax-M2.7": {}
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "${TELEGRAM_USER_ID}",
        "${TELEGRAM_PARTNER_ID}"
      ],
      "allowFrom": [
        "${TELEGRAM_USER_ID}",
        "${TELEGRAM_PARTNER_ID}"
      ],
      "streaming": {
        "mode": "off"
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add"
      ]
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "memory-core",
      "anthropic"
    ],
    "entries": {
      "telegram": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true
      },
      "anthropic": {
        "enabled": true
      }
    },
    "slots": {
      "memory": "memory-core"
    }
  },
  "models": {
    "providers": {
      "anthropic": {
        "api": "anthropic-messages",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "baseUrl": "https://api.anthropic.com",
        "models": [
          {
            "id": "claude-haiku-4-5-20251001",
            "name": "Claude Haiku 4.5",
            "input": [
              "text"
            ]
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "input": [
              "text"
            ]
          }
        ]
      },
      "minimax-direct": {
        "api": "openai-completions",
        "auth": "token",
        "apiKey": "${MINIMAX_API_KEY}",
        "baseUrl": "https://api.minimaxi.chat/v1",
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "input": [
              "text"
            ]
          },
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "input": [
              "text"
            ]
          }
        ]
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.8",
    "lastTouchedAt": "2026-04-08T18:11:38.599Z"
  },
  "memory": {
    "citations": "auto"
  },
  "wizard": {
