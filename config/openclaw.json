{
  "agents": {
    "defaults": {
      "model": "minimax/MiniMax-M2.7",
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {}
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      },
      "memorySearch": {
        "enabled": false
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": { "enabled": true },
        "boot-md": { "enabled": true },
        "command-logger": { "enabled": true }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["${TELEGRAM_USER_ID}", "${TELEGRAM_PARTNER_ID}"],
      "allowFrom": ["${TELEGRAM_USER_ID}", "${TELEGRAM_PARTNER_ID}"],
      "streaming": "off"
    },
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${WHATSAPP_USER_PHONE}"]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "remote",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add"
      ]
    },
    "remote": {
      "url": "ws://127.0.0.1:18789"
    }
  },
  "plugins": {
    "allow": ["telegram", "whatsapp", "memory-core"],
    "entries": {
      "telegram": { "enabled": true },
      "whatsapp": { "enabled": true },
      "memory-core": { "enabled": true }
    },
    "slots": {
      "memory": "memory-core"
    }
  },
  "models": {
    "providers": {
      "minimax": {
        "api": "anthropic-messages",
        "auth": "token",
        "apiKey": "${MINIMAX_API_KEY}",
        "baseUrl": "https://api.minimax.io/anthropic",
        "models": [
          { "id": "MiniMax-M2.7", "name": "MiniMax M2.7", "input": ["text"] },
          { "id": "MiniMax-M2.5", "name": "MiniMax M2.5", "input": ["text"] }
        ]
      },
      "anthropic": {
        "api": "anthropic-messages",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "baseUrl": "https://api.anthropic.com",
        "models": [
          { "id": "claude-haiku-4-5-20251001", "name": "Claude Haiku 4.5", "input": ["text"] },
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6", "input": ["text"] }
        ]
      }
    }
  }
}
